datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
}

model User {
  id               String            @id @db.Uuid
  email            String            @unique
  username         String            @unique
  firstName        String            @map("first_name")
  lastName         String            @map("last_name")
  createdAt        DateTime          @default(now()) @map("created_at")
  allowanceCycles  AllowanceCycle[]
  transactions     Transaction[]
  financialWeather FinancialWeather?

  @@map("users")
}

model AllowanceCycle {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  amount       Decimal       @db.Decimal(10, 2)
  cadence      String        // "WEEKLY", "BI_WEEKLY", "MONTHLY"
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("allowance_cycles")
}

model Transaction {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  cycleId   String         @map("cycle_id") @db.Uuid
  amount    Decimal        @db.Decimal(10, 2) // Negative for expenses, positive for inflow/allowance
  category  String         // "FOOD", "COMMUTE", "DORM", "SCHOOL", "ADJUSTMENT", "ALLOWANCE"
  merchant  String?
  timestamp DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle     AllowanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  // Critical performance indexes for time-series analytics execution
  @@index([userId, timestamp])
  @@index([cycleId])
  @@map("transactions")
}

model FinancialWeather {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  status     String   // "CLEAR", "CLOUDY", "STORM", "FLOOD"
  runwayDays Int      @map("runway_days")
  volatility Decimal  @db.Decimal(5, 4)
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_weather")
}